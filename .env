# ===========================================
# Marani Transcription App - Environment Variables
# ===========================================

# ===========================================
# REQUIRED: Gemini API Key (for text processing)
# ===========================================
# Get your free API key from: https://aistudio.google.com/app/apikey
# Used for: Cleaning, formatting, summarizing transcripts
GEMINI_API_KEY="your-gemini-api-key-here"

# ===========================================
# OPTIONAL: OpenAI API Key (for Whisper transcription)
# ===========================================
# Get from: https://platform.openai.com/api-keys
# Used for: High-quality audio transcription
# If not provided, falls back to Hugging Face (free, no key needed)
OPENAI_API_KEY="your-openai-api-key-here"

# ===========================================
# OPTIONAL: Hugging Face Token (fallback transcription)
# ===========================================
# Get from: https://huggingface.co/settings/tokens
# Used for: Free transcription when OpenAI key is not available
# Can work without token for basic usage (rate limited)
HUGGINGFACE_TOKEN="your-huggingface-token-here"

# ===========================================
# App Configuration
# ===========================================
# Port for the backend server
PORT=3001

# URL where the app is hosted (for callbacks, etc.)
APP_URL="http://localhost:3000"
